.bg-glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(140px);
  pointer-events: none;
  opacity: 0.6;
}

.bg-glow-match {
  width: 520rpx;
  height: 520rpx;
  background: rgba(175, 82, 222, 0.07);
  top: -180rpx;
  left: -160rpx;
}

.page-header {
  width: 100%;
  margin-top: 24rpx;
  margin-bottom: 36rpx;
  position: relative;
  z-index: 1;
}

.page-title {
  font-size: 44rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  line-height: 1.2;
}

.page-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 8rpx;
}

/* 选择器 */
.selector-section {
  width: 100%;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.selector-label {
  font-size: 22rpx;
  font-weight: var(--font-semibold);
  color: var(--text-tertiary);
  margin-bottom: 16rpx;
  display: block;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.type-scroll {
  width: 100%;
  white-space: nowrap;
}

.type-chips {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx 0;
}

.type-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 22rpx;
  border-radius: var(--radius-xl);
  border: 0.5px solid var(--border);
  background: var(--surface);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  flex-shrink: 0;
  transition: all 0.15s;
}

.chip-active {
  border-width: 1px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}

.chip-emoji {
  font-size: 26rpx;
  line-height: 1;
}

.chip-code {
  font-size: 24rpx;
  font-weight: var(--font-bold);
  letter-spacing: 1rpx;
}

/* VS / 交换 */
.vs-divider {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  position: relative;
  z-index: 1;
}

.vs-line {
  flex: 1;
  height: 0.5px;
  background: var(--border);
}

.vs-swap {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-xl);
  background: var(--surface);
  border: 0.5px solid var(--border);
  transition: transform 0.15s ease;
}

.vs-swap:active {
  transform: scale(0.92) rotate(180deg);
}

.vs-text {
  font-size: 26rpx;
  font-weight: var(--font-bold);
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

.vs-swap-icon {
  font-size: 26rpx;
  color: var(--accent);
}

/* 匹配结果卡 */
.match-card {
  width: 100%;
  padding: 40rpx 36rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.score-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: background 0.5s ease;
}

.score-ring-inner {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.04);
}

.score-num {
  font-size: 52rpx;
  font-weight: var(--font-bold);
  letter-spacing: 1rpx;
  line-height: 1.4;
}

.score-unit {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.match-level {
  font-size: 32rpx;
  font-weight: var(--font-bold);
  margin-bottom: 28rpx;
}

.match-stats {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  border: 0.5px solid var(--border);
  margin-bottom: 36rpx;
}

.match-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.match-stat-value {
  font-size: 28rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
  line-height: 1.2;
}

.match-stat-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.match-stat-divider {
  width: 0.5px;
  height: 44rpx;
  background: var(--border);
}

/* match sections */
.match-section {
  width: 100%;
  padding: 28rpx 0;
}

.match-section-title {
  font-size: 26rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 14rpx;
}

.match-section-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.75;
}

.match-cta {
  width: 100%;
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.match-cta .btn-primary,
.match-cta .btn-secondary {
  width: 100%;
}
