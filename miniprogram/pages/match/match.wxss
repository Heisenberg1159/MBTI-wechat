.page-header {
  width: 100%;
  margin-top: 12rpx;
  margin-bottom: 36rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  line-height: 1.2;
}

.page-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-top: 8rpx;
}

/* 选择器 */
.selector-section {
  width: 100%;
  margin-bottom: 8rpx;
}

.selector-label {
  font-size: 22rpx;
  font-weight: var(--font-semibold);
  color: var(--text-tertiary);
  margin-bottom: 16rpx;
  display: block;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.type-scroll {
  width: 100%;
  white-space: nowrap;
}

.type-chips {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx 0;
}

.type-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 22rpx;
  border-radius: var(--radius-xl);
  border: 0.5px solid var(--border);
  background: var(--surface);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  flex-shrink: 0;
  transition: all 0.15s;
}

.chip-active {
  border-width: 1px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}

.chip-emoji {
  font-size: 26rpx;
  line-height: 1;
}

.chip-code {
  font-size: 24rpx;
  font-weight: var(--font-bold);
  letter-spacing: 1rpx;
}

/* VS */
.vs-divider {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
}

.vs-line {
  flex: 1;
  height: 0.5px;
  background: var(--border);
}

.vs-text {
  font-size: 28rpx;
  font-weight: var(--font-bold);
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
}

/* 匹配结果卡 */
.match-card {
  width: 100%;
  padding: 40rpx 36rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-ring-wrap {
  margin-bottom: 12rpx;
}

.score-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-primary);
}

.score-num {
  font-size: 44rpx;
  font-weight: var(--font-bold);
  letter-spacing: 1rpx;
}

.match-level {
  font-size: 32rpx;
  font-weight: var(--font-bold);
  margin-bottom: 28rpx;
}

.match-stats {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  border: 0.5px solid var(--border);
  margin-bottom: 36rpx;
}

.match-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.match-stat-value {
  font-size: 28rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
  line-height: 1.2;
}

.match-stat-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.match-stat-divider {
  width: 0.5px;
  height: 44rpx;
  background: var(--border);
}

/* match sections */
.match-section {
  width: 100%;
  padding: 28rpx 0;
}

.match-section-title {
  font-size: 26rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 14rpx;
}

.match-section-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.75;
}

.match-cta {
  width: 100%;
  margin-top: 36rpx;
  padding-bottom: 80rpx;
}
