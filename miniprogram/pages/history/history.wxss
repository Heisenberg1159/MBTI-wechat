.clear-btn:active {
  color: #FF3B30;
  border-color: rgba(255, 59, 48, 0.3);
}

/* 汇总卡 */
.summary-card {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.summary-emoji {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 48rpx;
  flex-shrink: 0;
}

.summary-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.summary-line {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.summary-strong {
  font-size: 30rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
}

.summary-dominant {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.summary-code {
  font-size: 28rpx;
  font-weight: var(--font-bold);
  letter-spacing: 1rpx;
}

.summary-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.empty-result {
  position: relative;
  z-index: 1;
}

.history-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  background: var(--surface);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.03);
  transition: all 0.15s;
}

.history-item:active {
  background: var(--surface-hover);
  border-color: var(--border-hover);
  transform: scale(0.99);
}

.history-emoji {
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.history-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.history-code {
  font-size: 34rpx;
  font-weight: var(--font-bold);
  letter-spacing: 2rpx;
}

.history-name {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.history-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.history-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: var(--font-light);
  flex-shrink: 0;
}
