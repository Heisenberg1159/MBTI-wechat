/* 类型头 */
.type-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 36rpx 40rpx;
  margin-top: 0;
  width: 100%;
  box-sizing: border-box;
  background: var(--surface);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.04);
}

.type-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
}

.type-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.type-code {
  font-size: 60rpx;
  font-weight: var(--font-bold);
  letter-spacing: 6rpx;
  line-height: 1.1;
}

.type-name {
  font-size: 34rpx;
  font-weight: var(--font-semibold);
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.type-tagline {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
  text-align: center;
  line-height: 1.45;
}

.type-traits {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
}

/* section */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  line-height: 1.35;
}

.section-subtitle {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

/* 描述 */
.desc-card {
  width: 100%;
  padding: 40rpx 36rpx;
  margin-top: 28rpx;
  box-sizing: border-box;
}

.desc-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.85;
}

/* 优劣势 */
.sw-card {
  width: 100%;
  padding: 40rpx 36rpx;
  margin-top: 28rpx;
  box-sizing: border-box;
}

.sw-section {
  margin-bottom: 28rpx;
}

.sw-section-last {
  margin-bottom: 0;
  padding-top: 28rpx;
}

.sw-label {
  font-size: 24rpx;
  font-weight: var(--font-bold);
  margin-bottom: 16rpx;
  display: block;
}

.sw-strength { color: #34C759; }
.sw-weakness { color: #FF9500; }

.sw-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sw-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.sw-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 14rpx;
}

.sw-dot-strength { background: #34C759; box-shadow: 0 0 6rpx rgba(52, 199, 89, 0.3); }
.sw-dot-weakness { background: #FF9500; box-shadow: 0 0 6rpx rgba(255, 149, 0, 0.3); }

/* 职业 */
.career-card {
  width: 100%;
  padding: 40rpx 36rpx;
  margin-top: 28rpx;
  box-sizing: border-box;
}

.career-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.career-tag {
  padding: 10rpx 24rpx;
  border-radius: var(--radius-xl);
  font-size: 22rpx;
  font-weight: var(--font-medium);
  line-height: 1.4;
}

/* 匹配 */
.compat-card {
  width: 100%;
  padding: 40rpx 36rpx;
  margin-top: 28rpx;
  box-sizing: border-box;
}

.compat-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.compat-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  border: 0.5px solid var(--border);
  transition: all 0.15s;
}

.compat-item:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.compat-emoji {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
}

.compat-info {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.compat-code {
  font-size: 26rpx;
  font-weight: var(--font-bold);
  letter-spacing: 2rpx;
}

.compat-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.compat-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: var(--font-light);
  flex-shrink: 0;
}

/* CTA */
.detail-cta {
  width: 100%;
  margin-top: 40rpx;
  padding-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.detail-cta-link {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: var(--font-medium);
}
