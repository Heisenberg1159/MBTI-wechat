/* 类型头卡 — 仅保留 type-detail 特有的覆盖 */
.type-hero {
  margin-top: 0;
}

/* 卡片层级 */
.desc-card,
.sw-card,
.career-card,
.compat-card {
  position: relative;
  z-index: 1;
}

/* CTA */
.detail-cta {
  width: 100%;
  margin-top: 40rpx;
  padding-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.detail-cta-link {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: var(--font-medium);
}
