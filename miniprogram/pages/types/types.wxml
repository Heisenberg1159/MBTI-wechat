<view class="container tab-safe" style="padding-top: {{statusBarHeight}}px">
  <view class="bg-glow bg-glow-types"></view>

  <view class="page-header">
    <text class="page-title">16 种人格</text>
    <text class="page-subtitle">探索每一种性格的独特之处</text>
  </view>

  <view class="type-grid">
    <view
      class="type-card card"
      wx:for="{{types}}"
      wx:key="code"
      bindtap="viewDetail"
      data-code="{{item.code}}"
      style="border-color: {{item.softColor}}"
    >
      <view class="type-card-emoji" style="background: {{item.softColor}}">
        <text>{{item.emoji}}</text>
      </view>
      <text class="type-card-code" style="color: {{item.color}}">{{item.code}}</text>
      <text class="type-card-name">{{item.name}}</text>
      <text class="type-card-tagline">{{item.tagline}}</text>
    </view>
  </view>
</view>
