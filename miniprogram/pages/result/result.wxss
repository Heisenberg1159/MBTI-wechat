.result-page {
  position: relative;
  overflow: hidden;
  padding-bottom: 72rpx;
}

.bg-glow-result {
  position: fixed;
  width: 600rpx;
  height: 600rpx;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 50%;
  filter: blur(160px);
  opacity: 0.12;
  pointer-events: none;
}

/* 类型头卡 — 仅保留 result 特有的覆盖 */
.type-hero {
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
  animation: heroIn 0.5s cubic-bezier(0.22, 0.61, 0.36, 1) both;
}

@keyframes heroIn {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 统计区 */
.type-stats {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  padding: 24rpx 0;
  border-radius: var(--radius-md);
  background: var(--bg-primary);
  border: 0.5px solid var(--border);
}

.type-stat {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.type-stat-value {
  font-size: 32rpx;
  font-weight: var(--font-bold);
  color: var(--text-primary);
  line-height: 1.2;
}

.type-stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.type-stat-divider {
  width: 0.5px;
  height: 52rpx;
  background: var(--border);
}

/* 卡片层级 — 置于 bg-glow 之上 */
.dimensions-card,
.desc-card,
.sw-card,
.career-card,
.compat-card {
  position: relative;
  z-index: 1;
}

/* 维度图 */
.dim-chart {
  display: flex;
  flex-direction: column;
}

.dim-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 0 30rpx;
  margin-bottom: 30rpx;
  border-bottom: 0.5px solid var(--border);
}

.dim-row:last-child {
  padding-bottom: 0;
  margin-bottom: 0;
  border-bottom: none;
}

.dim-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.dim-title {
  font-size: 24rpx;
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  flex-shrink: 0;
}

.dim-result {
  font-size: 22rpx;
  font-weight: var(--font-semibold);
  text-align: right;
  line-height: 1.35;
}

.dim-axis {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dim-side {
  width: 68rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  align-items: flex-start;
}

.dim-side-right {
  align-items: flex-end;
}

.dim-code {
  font-size: 26rpx;
  font-weight: var(--font-bold);
  line-height: 1.1;
}

.dim-side-name {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.dim-track {
  flex: 1;
  height: 10rpx;
  background: var(--bg-hover);
  border-radius: 999rpx;
  position: relative;
  overflow: visible;
}

.dim-fill {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  border-radius: 999rpx;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.dim-indicator {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 22rpx;
  height: 22rpx;
  background: var(--bg-primary);
  border: 3rpx solid var(--accent);
  border-radius: 50%;
  box-shadow: 0 0 12rpx var(--accent-glow), 0 2px 8px rgba(0,0,0,0.06);
  transition: left 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.dim-score-line {
  display: flex;
  justify-content: space-between;
  padding: 0 84rpx;
  box-sizing: border-box;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* 操作区 */
.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}

.btn-share,
.action-btn,
.empty-action {
  margin: 0;
  padding: 0;
}

.btn-share {
  width: 100%;
}

.secondary-actions {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  min-width: 180rpx;
}

/* 空状态 */
.empty-result {
  position: relative;
  z-index: 1;
}
