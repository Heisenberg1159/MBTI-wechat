<view class="container" style="padding-top: {{statusBarHeight}}px">
  <view class="nav-home">
    <view class="nav-home-btn" bindtap="goHome">
      <text class="nav-home-icon">⌂</text>
      <text class="nav-home-text">首页</text>
    </view>
  </view>
  <view class="card-preview" wx:if="{{cardReady}}">
    <canvas
      type="2d"
      id="shareCanvas"
      class="share-canvas"
      style="width: 630rpx; height: 900rpx"
    ></canvas>
  </view>

  <view class="card-loading" wx:else>
    <text class="loading-text">正在生成卡片...</text>
  </view>

  <view class="card-actions" wx:if="{{cardReady}}">
    <button class="btn-primary" bindtap="saveToAlbum">保存到相册</button>
    <button class="btn-secondary" bindtap="goBack">返回</button>
    <text class="save-hint">保存后即可分享给朋友</text>
  </view>
</view>
