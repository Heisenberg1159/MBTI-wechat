<view class="container">
  <nav-bar></nav-bar>

  <view class="card-stage">
    <canvas
      type="2d"
      id="shareCanvas"
      class="share-canvas {{cardReady ? 'canvas-ready' : ''}}"
      style="width: 630rpx; height: 920rpx"
    ></canvas>

    <view class="card-loading" wx:if="{{!cardReady}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在生成卡片…</text>
    </view>
  </view>

  <view class="card-actions">
    <button class="btn-primary" bindtap="saveToAlbum" disabled="{{!cardReady}}">保存到相册</button>
    <button class="btn-secondary" open-type="share">分享给朋友</button>
    <text class="save-hint">保存后可发朋友圈，或直接分享给好友</text>
  </view>
</view>
