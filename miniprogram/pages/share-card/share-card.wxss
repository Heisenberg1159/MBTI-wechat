.card-preview {
  margin-top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.share-canvas {
  border-radius: var(--radius-lg);
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
  background: #FFFFFF;
}

.card-loading {
  margin-top: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.card-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 48rpx;
  gap: 16rpx;
}

.card-actions .btn-primary {
  width: 100%;
}

.save-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
