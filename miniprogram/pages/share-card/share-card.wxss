.card-stage {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 630rpx;
  height: 920rpx;
  margin-top: 12rpx;
}

.share-canvas {
  border-radius: var(--radius-lg);
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12);
  background: #FFFFFF;
  opacity: 0;
  transform: scale(0.96);
  transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.canvas-ready {
  opacity: 1;
  transform: scale(1);
}

.card-loading {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.card-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 44rpx;
  gap: 16rpx;
}

.card-actions .btn-primary,
.card-actions .btn-secondary {
  width: 100%;
}

.card-actions .btn-primary[disabled] {
  opacity: 0.5;
}

.save-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}
